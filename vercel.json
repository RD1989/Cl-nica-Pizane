{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "admin/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "rewrites": [
        {
            "source": "/",
            "destination": "/site/index.html"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1.php"
        },
        {
            "source": "/admin",
            "destination": "/admin/index.php"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/admin/$1.php"
        }
    ]
}