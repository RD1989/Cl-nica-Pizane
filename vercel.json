{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "rewrites": [
        {
            "source": "/",
            "destination": "/site/index.html"
        },
        {
            "source": "/api/agendar",
            "destination": "/api/agendar.php"
        },
        {
            "source": "/api/agendar.php",
            "destination": "/api/agendar.php"
        },
        {
            "source": "/admin",
            "destination": "/api/admin/index.php"
        },
        {
            "source": "/admin/login",
            "destination": "/api/admin/login.php"
        },
        {
            "source": "/admin/login.php",
            "destination": "/api/admin/login.php"
        },
        {
            "source": "/admin/logout",
            "destination": "/api/admin/logout.php"
        }
    ]
}